COMPOSE_PROJECT_NAME=my_superapp

SECRET_KEY=your_secret_key
DEBUG=true
ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=postgres://postgres:postgrespassword@127.0.0.1:5432/postgres
REDIS_BROKER_URL=redis://:redispassword@127.0.0.1:6379

POSTGRES_PASSWORD=postgrespassword
REDIS_PASSWORD=redispassword

# S3 Storage (optional - leave unset to use local FileSystemStorage)
# WARNING: Never use production bucket names or credentials here!
# AWS_PUBLIC_ACCESS_KEY_ID=
# AWS_PUBLIC_SECRET_ACCESS_KEY=
# AWS_PUBLIC_STORAGE_BUCKET_NAME=dev-radiocrestin-admin-public
# AWS_PUBLIC_ENDPOINT_URL=https://fsn1.your-objectstorage.com
# AWS_PUBLIC_LOCATION=public/
# AWS_PRIVATE_ACCESS_KEY_ID=
# AWS_PRIVATE_SECRET_ACCESS_KEY=
# AWS_PRIVATE_STORAGE_BUCKET_NAME=dev-radiocrestin-admin-private
# AWS_PRIVATE_ENDPOINT_URL=https://fsn1.your-objectstorage.com
# AWS_PRIVATE_LOCATION=private/
